TINYCC_DIR = ../inst/tinycc
# Only include the libtcc/ dir (for libtcc.h).  Do NOT add
# $(TINYCC_DIR)/include — that contains TCC's own system headers
# (stdlib.h, stdio.h, math.h …) which conflict with Rtools/MinGW.
PKG_CPPFLAGS = -I$(TINYCC_DIR)/libtcc

# Opt-in unstripped build for Windows gdb sessions.
ifeq ($(RTINYCC_DEBUG_BUILD),1)
RTINYCC_DEBUG_CFLAGS := $(CFLAGS)
RTINYCC_DEBUG_SHLIB_CXXLDFLAGS := $(SHLIB_CXXLDFLAGS)
RTINYCC_DEBUG_MAIN_LDFLAGS := $(MAIN_LDFLAGS)

override CFLAGS := $(filter-out -O2,$(RTINYCC_DEBUG_CFLAGS)) -O0 -g3 -fno-omit-frame-pointer
override SHLIB_CXXLDFLAGS := $(filter-out -s,$(RTINYCC_DEBUG_SHLIB_CXXLDFLAGS)) -g
override MAIN_LDFLAGS := $(filter-out -s,$(RTINYCC_DEBUG_MAIN_LDFLAGS))
endif

# Prefer dynamic linking against libtcc.dll (same strategy as Unix).
# This keeps _exit/abort/etc. out of Rtinycc.dll — they stay in the
# companion libtcc.dll which install.libs.R copies next to Rtinycc.dll.
LIBTCC_DLL := $(wildcard $(TINYCC_DIR)/lib/libtcc.dll)
WPKG_LIBS = -L$(TINYCC_DIR)/lib -ltcc
ifneq ($(LIBTCC_DLL),)
        PKG_LIBS = $(LIBTCC_DLL)
else
        PKG_LIBS = -L$(TINYCC_DIR)/lib -ltcc
endif

all: $(SHLIB)
